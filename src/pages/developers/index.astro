---
import Layout from '../../components/Layout.astro';
import Figure from '../../components/Figure.astro';
import B2BForm from '../../components/B2BForm.astro';
import { withBase } from '../../lib/img.js';
import { developers as d } from '../../data/content.js';
import { site } from '../../data/site.js';

const description =
  'Reform Architects для девелоперов: проектирование и BIM-координация общественных пространств жилых комплексов премиум- и бизнес-класса — от концепции до реализации. Работаем выборочно.';
---

<Layout title="Девелоперам" description={description} headerTransparent={true}>
  {/* 1 — Hero */}
  <section class="dev-hero">
    <div class="dev-hero__media" aria-hidden="true">
      <Figure
        name="developers-hero"
        alt="Reform Architects — общественные пространства жилых комплексов"
        fill={true}
        eager={true}
        imgClass="dev-hero__img"
      />
      <div class="dev-hero__veil"></div>
    </div>
    <div class="wrap dev-hero__inner">
      <p class="eyebrow dev-hero__eyebrow" data-reveal>Девелоперам · B2B</p>
      <h1 class="dev-hero__title" data-reveal>{d.hero.title}</h1>
      <p class="dev-hero__subtitle" data-reveal>{d.hero.subtitle}</p>
      <a href={withBase('#contact')} class="btn btn--light dev-hero__cta" data-reveal>
        {site.cta.b2b}<span class="btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  {/* 2 — Почему это решает */}
  <section class="section">
    <div class="wrap">
      <h2 class="eyebrow text-muted-light mb-8" data-reveal>Почему это решает</h2>
      <p class="dev-statement" data-reveal>{d.why.headline}</p>
      <div class="dev-points">
        {d.why.points.map((pt) => <p class="dev-point" data-reveal>{pt}</p>)}
      </div>
    </div>
  </section>

  {/* 3 — Что это даёт проекту (ROI) */}
  <section class="section bg-surface-dark text-ondark">
    <div class="wrap">
      <h2 class="eyebrow text-muted-dark mb-2" data-reveal>{d.roi.title}</h2>
      <div class="cards">
        {
          d.roi.items.map((it) => (
            <article class="card" data-reveal>
              <h3 class="card__title">{it.title}</h3>
              <p class="card__text">{it.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* 4 — Состав работ */}
  <section class="section">
    <div class="wrap">
      <h2 class="eyebrow text-muted-light mb-2" data-reveal>{d.scope.title}</h2>
      <ul class="scope-list">
        {d.scope.items.map((s) => <li class="scope-list__item" data-reveal>{s}</li>)}
      </ul>
      <p class="dev-scope-note" data-reveal>{d.scope.note}</p>
    </div>
  </section>

  {/* 5 — Что ещё делаем (ширина) */}
  <section class="section bg-surface-dark text-ondark">
    <div class="wrap">
      <h2 class="eyebrow text-muted-dark mb-2" data-reveal>{d.width.title}</h2>
      <div class="cards">
        {
          d.width.items.map((it) => (
            <article class="card" data-reveal>
              <h3 class="card__title">{it.title}</h3>
              <p class="card__text">{it.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* 6 — Почему с нами */}
  <section class="section">
    <div class="wrap dev-trust">
      <h2 class="eyebrow text-muted-light mb-8" data-reveal>Почему с нами</h2>
      <ul class="dev-facts" data-reveal>
        {d.trust.facts.map((f) => <li class="dev-fact">{f}</li>)}
      </ul>
      <p class="dev-trust__text" data-reveal>{d.trust.text}</p>
      <a href={withBase(d.trust.link.href)} class="arrow-link dev-trust__link" data-reveal>
        {d.trust.link.label}<span class="arr" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  {/* 7 — Форма (B2B) */}
  <B2BForm />
</Layout>

<style>
  .dev-hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: clamp(560px, 88svh, 820px);
    padding-top: calc(var(--header-h) + 2rem);
    padding-bottom: clamp(3rem, 2rem + 4vw, 5.5rem);
    background: #161616;
    color: #f4f2ec;
    overflow: hidden;
  }
  .dev-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .dev-hero :global(.dev-hero__img) {
    filter: brightness(0.5) grayscale(0.2);
  }
  .dev-hero__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(16, 16, 16, 0.55) 0%,
      rgba(16, 16, 16, 0.3) 40%,
      rgba(16, 16, 16, 0.8) 100%
    );
  }
  .dev-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
  }
  .dev-hero__eyebrow {
    color: rgba(244, 242, 236, 0.62);
  }
  .dev-hero__title {
    margin-top: 1.5rem;
    max-width: 20ch;
    font-size: clamp(2.3rem, 1.4rem + 3.6vw, 3.5rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
  }
  .dev-hero__subtitle {
    margin-top: 1.75rem;
    max-width: 56ch;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.0625rem, 1rem + 0.35vw, 1.1875rem);
    line-height: 1.55;
    color: rgba(244, 242, 236, 0.82);
  }
  .dev-hero__cta {
    margin-top: 2.5rem;
  }

  .dev-statement {
    max-width: 24ch;
    font-family: var(--font-sans);
    font-size: clamp(1.7rem, 1.2rem + 2.2vw, 2.75rem);
    font-weight: 300;
    line-height: 1.16;
    letter-spacing: -0.01em;
  }
  .dev-points {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 60ch;
  }
  .dev-point {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: #2b2b2a;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(20, 20, 20, 0.14);
  }

  .dev-scope-note {
    margin-top: 2.5rem;
    max-width: 48ch;
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 1.1rem + 0.8vw, 1.6rem);
    font-weight: 300;
    line-height: 1.3;
  }

  .dev-trust {
    max-width: 64ch;
  }
  .dev-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    list-style: none;
    margin-bottom: 2rem;
  }
  .dev-fact {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #141414;
    border: 1px solid rgba(20, 20, 20, 0.2);
    border-radius: 30px;
    padding: 0.5rem 1rem;
  }
  .dev-trust__text {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.0625rem, 1rem + 0.4vw, 1.25rem);
    line-height: 1.6;
    color: #2b2b2a;
  }
  .dev-trust__link {
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .dev-points {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }
</style>
