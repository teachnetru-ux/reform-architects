---
import Layout from '../../components/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import NumbersRow from '../../components/NumbersRow.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import Figure from '../../components/Figure.astro';
import LeadForm from '../../components/LeadForm.astro';
import { pillars, founders, teamRoles } from '../../data/content.js';

const description =
  'Бюро Reform Architects — архитектурное бюро полного цикла с 2016 года. Единый контур ответственности: проект, комплектация и реализация. Основатели и команда проекта.';
---

<Layout title="Бюро" description={description}>
  {/* Интро */}
  <section class="section section-top">
    <div class="wrap">
      <div data-reveal>
        <p class="eyebrow text-muted-light mb-5">Бюро</p>
        <h1 class="text-display max-w-[16ch]">Архитектурное бюро полного цикла</h1>
        <p class="mt-6 text-lead font-light text-muted-light max-w-prose">
          Проектируем дома, резиденции и интерьеры и ведём их до реализации в едином контуре
          ответственности. С 2016 года.
        </p>
      </div>
    </div>
  </section>

  {/* Философия */}
  <section class="section pt-0">
    <div class="wrap">
      <SectionHeading
        eyebrow="Философия"
        title="Премиальность — это управляемость."
        lead="Уровень определяется не ценой материалов, а системой, в которой результат предсказуем на каждом этапе. Красивая визуализация — это обещание. Мы отвечаем за то, чтобы обещание стало пространством."
      />
      <div class="pillars">
        {
          pillars.map((p, i) => (
            <article class="pillar" data-reveal>
              <span class="pillar__num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="pillar__title">{p.title}</h3>
              <p class="pillar__text">{p.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* Цифры */}
  <section class="section bg-surface-dark text-ondark">
    <div class="wrap">
      <SectionHeading eyebrow="Цифры" title="Опыт, который можно измерить" tone="dark" />
      <div class="mt-12 md:mt-16">
        <NumbersRow />
      </div>
    </div>
  </section>

  {/* Процесс */}
  <section class="section">
    <div class="wrap">
      <SectionHeading
        eyebrow="Процесс"
        title="Процесс с предсказуемым результатом на каждом этапе"
        lead="Этап завершается зафиксированным решением — вы всегда понимаете, что происходит и что дальше."
      />
      <div class="mt-12 md:mt-16">
        <ProcessSteps />
      </div>
    </div>
  </section>

  {/* Команда */}
  <section class="section bg-surface-dark text-ondark">
    <div class="wrap">
      <SectionHeading eyebrow="Команда" title="Основатели" tone="dark" />
      <div class="founders">
        {
          founders.map((f) => (
            <article class="founder" data-reveal>
              <Figure
                name={f.image}
                alt={`${f.name} — основатель Reform Architects`}
                ratio="3 / 4"
                imgClass="founder__img"
              />
              <h3 class="founder__name">{f.name}</h3>
              <p class="founder__role">{f.role}</p>
            </article>
          ))
        }
      </div>
      <div class="roles" data-reveal>
        <p class="eyebrow text-muted-dark">Команда проекта</p>
        <ul class="roles__list">
          {teamRoles.map((r) => <li class="roles__item">{r}</li>)}
        </ul>
      </div>
    </div>
  </section>

  {/* Форма */}
  <LeadForm />
</Layout>
