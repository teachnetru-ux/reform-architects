---
import { numbers } from '../data/content.js';
---

<dl class="nums">
  {
    numbers.map((n) => (
      <div class="num" data-reveal>
        <dt class="num__value">{n.value}</dt>
        <dd class="num__label">{n.label}</dd>
      </div>
    ))
  }
</dl>

<style>
  .nums {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .num {
    padding-top: 1.5rem;
    border-top: 1px solid rgba(244, 242, 236, 0.14);
  }
  .num__value {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 1.6rem + 4vw, 4rem);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .num__label {
    margin-top: 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(244, 242, 236, 0.6);
    max-width: 26ch;
  }
  @media (min-width: 768px) {
    .nums {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
</style>
