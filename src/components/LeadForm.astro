---
/**
 * Частная форма захвата: Имя · Телефон · Тип объекта · согласие.
 * CTA «Обсудить Ваш проект». Всегда на светлой поверхности.
 */
import { site } from '../data/site.js';
import { withBase } from '../lib/img.js';

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  /** Если задан — на корневой <section> ставится data-scroll-goal (scroll-аналитика, только на главной). */
  scrollGoal?: string;
  /** Тип формы для скрытого поля form_type (по умолчанию 'private'; 'family' — партнёрский лендинг Family). */
  formType?: string;
  /** Опциональная доп. строка под формой (напр., условия программы ВТБ Family). */
  programNote?: string;
}
const {
  id = 'contact',
  eyebrow = 'Контакт',
  title = 'Обсудим ваш проект',
  subtitle = 'Расскажите, что планируете — предложим следующий шаг.',
  scrollGoal,
  formType = 'private',
  programNote,
} = Astro.props;

const uid = Math.random().toString(36).slice(2, 8);
---

<section id={id} class="section form-section" data-scroll-goal={scrollGoal}>
  <div class="wrap">
    <div class="form-layout">
      <div class="form-intro" data-reveal>
        <p class="eyebrow text-muted-light mb-5">{eyebrow}</p>
        <h2 class="text-h2">{title}</h2>
        <p class="mt-4 text-lead text-muted-light">{subtitle}</p>
        <p class="form-note">Мы не передаём ваши контакты третьим лицам.</p>
        {programNote && <p class="form-note">{programNote}</p>}
      </div>

      <form class="lead-form" action="/lead.php" method="POST" data-lead data-reveal>
        <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;" />
        <div class="form-body" data-form-body>
          <div class="field">
            <label for={`name-${uid}`}>Имя</label>
            <input id={`name-${uid}`} name="name" type="text" autocomplete="name" required />
          </div>
          <div class="field">
            <label for={`phone-${uid}`}>Телефон</label>
            <input
              id={`phone-${uid}`}
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              placeholder="+7 (___) ___-__-__"
              pattern="\+7 \(\d{3}\) \d{3}-\d{2}-\d{2}"
              title="Введите номер в формате +7 (999) 123-45-67"
              data-phone-mask
              required
            />
          </div>
          <div class="field">
            <label for={`type-${uid}`}>Тип объекта</label>
            <select id={`type-${uid}`} name="project_type" required>
              <option value="" selected disabled>Выберите</option>
              <option value="Дом">Дом</option>
              <option value="Квартира">Квартира</option>
              <option value="Коммерция">Коммерция</option>
            </select>
          </div>

          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>
              Я даю согласие на обработку
              <a
                href={withBase('/legal/consent/')}
                target="_blank"
                rel="noopener noreferrer">персональных данных</a>
            </span>
          </label>

          <input type="hidden" name="utm_source" />
          <input type="hidden" name="utm_medium" />
          <input type="hidden" name="utm_campaign" />
          <input type="hidden" name="utm_term" />
          <input type="hidden" name="utm_content" />
          <input type="hidden" name="utm_referrer" />
          <input type="hidden" name="utm_page" />
          <input type="hidden" name="form_type" value={formType} />

          <button type="submit" class="btn btn--solid form-submit">
            {site.cta.private}<span class="btn__arrow" aria-hidden="true">→</span>
          </button>
        </div>

        <p class="form-success" data-form-success hidden tabindex="-1">
          Заявка отправлена — свяжемся в течение дня.
        </p>
        <p class="form-success" data-form-error hidden tabindex="-1">
          Что-то пошло не так, попробуйте ещё раз или напишите нам напрямую.
        </p>
      </form>
    </div>
  </div>
</section>
