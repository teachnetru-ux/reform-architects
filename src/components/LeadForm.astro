---
/**
 * Частная форма захвата: Имя · Телефон · Тип объекта · согласие.
 * CTA «Обсудить Ваш проект». Всегда на светлой поверхности.
 */
import { site } from '../data/site.js';
import { withBase } from '../lib/img.js';

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}
const {
  id = 'contact',
  eyebrow = 'Контакт',
  title = 'Обсудим ваш проект',
  subtitle = 'Расскажите, что планируете — предложим следующий шаг.',
} = Astro.props;

const endpoint = site.formEndpoint;
const demo = !endpoint;
const uid = Math.random().toString(36).slice(2, 8);
---

<section id={id} class="section form-section">
  <div class="wrap">
    <div class="form-layout">
      <div class="form-intro" data-reveal>
        <p class="eyebrow text-muted-light mb-5">{eyebrow}</p>
        <h2 class="text-h2">{title}</h2>
        <p class="mt-4 text-lead text-muted-light">{subtitle}</p>
        <p class="form-note">Мы не передаём ваши контакты третьим лицам.</p>
      </div>

      <form
        class="lead-form"
        action={endpoint || '#'}
        method="POST"
        data-demo={demo ? '' : undefined}
        data-reveal
      >
        <div class="form-body" data-form-body>
          <div class="field">
            <label for={`name-${uid}`}>Имя</label>
            <input id={`name-${uid}`} name="name" type="text" autocomplete="name" required />
          </div>
          <div class="field">
            <label for={`phone-${uid}`}>Телефон</label>
            <input
              id={`phone-${uid}`}
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              placeholder="+7 (___) ___-__-__"
              pattern="\+7 \(\d{3}\) \d{3}-\d{2}-\d{2}"
              title="Введите номер в формате +7 (999) 123-45-67"
              data-phone-mask
              required
            />
          </div>
          <div class="field">
            <label for={`type-${uid}`}>Тип объекта</label>
            <select id={`type-${uid}`} name="object_type" required>
              <option value="" selected disabled>Выберите</option>
              <option value="house">Дом</option>
              <option value="apartment">Квартира</option>
              <option value="commercial">Коммерция</option>
            </select>
          </div>

          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>
              Я даю согласие на обработку
              <a
                href={withBase('/legal/consent/')}
                target="_blank"
                rel="noopener noreferrer">персональных данных</a>
            </span>
          </label>

          <button type="submit" class="btn btn--solid form-submit">
            {site.cta.private}<span class="btn__arrow" aria-hidden="true">→</span>
          </button>
        </div>

        <p class="form-success" data-form-success hidden tabindex="-1">
          Спасибо — заявка принята. Мы свяжемся с вами в ближайшее время.
        </p>
      </form>
    </div>
  </div>
</section>
