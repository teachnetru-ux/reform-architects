---
import { projectTabs } from '../data/projects.js';
import { withBase } from '../lib/img.js';

interface Props {
  active: string;
}
const { active } = Astro.props;
---

<nav class="pills" aria-label="Категории проектов">
  {
    projectTabs.map((t) => (
      <a
        href={withBase(t.href)}
        class:list={['pill', active === t.key && 'pill--active']}
        aria-current={active === t.key ? 'page' : undefined}
      >
        {t.label}
      </a>
    ))
  }
</nav>

<style>
  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(20, 20, 20, 0.18);
    border-radius: 30px;
    padding: 0.6rem 1.1rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #141414;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .pill:hover {
    border-color: #141414;
  }
  .pill--active {
    background: #141414;
    color: #f4f2ec;
    border-color: #141414;
  }
</style>
