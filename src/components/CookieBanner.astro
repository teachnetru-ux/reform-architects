---
import { withBase } from '../lib/img.js';
---

<aside class="cookie glass-light" data-cookie hidden aria-label="Уведомление об использовании cookie">
  <p class="cookie__text">
    Мы используем cookie, чтобы сайт работал корректно и был удобнее. Оставаясь здесь, вы
    соглашаетесь с
    <a href={withBase('/legal/cookie/')} class="cookie__link">политикой использования cookie</a>.
  </p>
  <button type="button" class="btn btn--solid cookie__btn" data-cookie-accept>Хорошо</button>
</aside>

<script>
  const KEY = 'ra-cookie-ack';
  const el = document.querySelector<HTMLElement>('[data-cookie]');
  if (el) {
    let ack: string | null = null;
    try {
      ack = localStorage.getItem(KEY);
    } catch {}
    if (!ack) {
      el.hidden = false;
      requestAnimationFrame(() => el.classList.add('is-in'));
    }
    el.querySelector('[data-cookie-accept]')?.addEventListener('click', () => {
      try {
        localStorage.setItem(KEY, '1');
      } catch {}
      el.classList.remove('is-in');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) el.hidden = true;
      else window.setTimeout(() => (el.hidden = true), 360);
    });
  }
</script>

<style>
  .cookie {
    position: fixed;
    z-index: 60;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border-radius: 22px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    color: #141414;
    box-shadow: 0 16px 44px rgba(20, 20, 20, 0.18);
    transform: translateY(18px);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease;
  }
  .cookie.is-in {
    transform: none;
    opacity: 1;
  }
  .cookie[hidden] {
    display: none;
  }
  .cookie__text {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
  }
  .cookie__link {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cookie__btn {
    align-self: flex-start;
    padding: 0.75rem 1.5rem;
  }
  @media (min-width: 640px) {
    .cookie {
      left: auto;
      right: 24px;
      bottom: 24px;
      max-width: 440px;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    .cookie__btn {
      align-self: auto;
      flex: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cookie {
      transition: none;
      transform: none;
    }
  }
</style>
