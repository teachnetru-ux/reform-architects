---
/**
 * B2B-форма (девелоперы): Компания · Проект/ЖК · Роль · Контакт.
 * CTA «Запросить встречу».
 */
import { site } from '../data/site.js';
import { developers } from '../data/content.js';

interface Props {
  id?: string;
}
const { id = 'contact' } = Astro.props;

const endpoint = site.formEndpoint;
const demo = !endpoint;
const uid = Math.random().toString(36).slice(2, 8);
---

<section id={id} class="section form-section">
  <div class="wrap">
    <div class="form-layout">
      <div class="form-intro" data-reveal>
        <p class="eyebrow text-muted-light mb-5">Девелоперам</p>
        <h2 class="text-h2">{developers.form.title}</h2>
        <p class="mt-4 text-lead text-muted-light">{developers.form.subtitle}</p>
        <p class="form-note">Работаем выборочно. Отвечаем по существу запроса.</p>
      </div>

      <form
        class="lead-form"
        action={endpoint || '#'}
        method="POST"
        data-demo={demo ? '' : undefined}
        data-reveal
      >
        <div class="form-body" data-form-body>
          <div class="field">
            <label for={`company-${uid}`}>Компания</label>
            <input id={`company-${uid}`} name="company" type="text" autocomplete="organization" required />
          </div>
          <div class="field">
            <label for={`project-${uid}`}>Проект / ЖК</label>
            <input id={`project-${uid}`} name="project" type="text" required />
          </div>
          <div class="field">
            <label for={`role-${uid}`}>Ваша роль</label>
            <input id={`role-${uid}`} name="role" type="text" autocomplete="organization-title" required />
          </div>
          <div class="field">
            <label for={`contact-${uid}`}>Контакт (телефон или email)</label>
            <input id={`contact-${uid}`} name="contact" type="text" autocomplete="email" required />
          </div>

          <button type="submit" class="btn btn--solid form-submit">
            {site.cta.b2b}<span class="btn__arrow" aria-hidden="true">→</span>
          </button>
        </div>

        <p class="form-success" data-form-success hidden tabindex="-1">
          Спасибо — запрос принят. Свяжемся с вами, чтобы согласовать встречу.
        </p>
      </form>
    </div>
  </div>
</section>
