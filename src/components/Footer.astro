---
import { site } from '../data/site.js';
import { withBase } from '../lib/img.js';
---

<footer class="site-footer" id="footer">
  <div class="wrap section-sm">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={withBase('/')} class="footer-wordmark" aria-label={`${site.name} — на главную`}>
          reform architects
        </a>
        <p class="footer-about">
          Архитектурное бюро полного цикла. Проектируем дома, резиденции и интерьеры и ведём их до
          реализации в едином контуре ответственности.
        </p>
        <a href={withBase('#contact')} class="btn btn--light footer-cta">
          {site.cta.private}<span class="btn__arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <nav class="footer-col" aria-label="Подвал — разделы">
        <p class="eyebrow footer-col__title">Разделы</p>
        {site.nav.map((item) => <a href={withBase(item.href)} class="footer-link">{item.label}</a>)}
      </nav>

      <div class="footer-col">
        <p class="eyebrow footer-col__title">Контакты</p>
        <a href={`mailto:${site.email}`} class="footer-link">{site.email}</a>
        <a href={`tel:${site.phoneHref}`} class="footer-link">{site.phone}</a>
        <span class="footer-link footer-link--static">{site.domain}</span>
      </div>
    </div>

    <hr class="hairline-dark footer-rule" />

    <div class="footer-bottom">
      <p class="footer-copy">© {site.copyrightYears} {site.name} · {site.tagline}</p>
      <nav class="footer-legal" aria-label="Правовые документы">
        {site.legal.map((l) => <a href={withBase(l.href)} class="footer-legal__link">{l.label}</a>)}
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #161616;
    color: #f4f2ec;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .footer-wordmark {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1;
  }
  .footer-about {
    margin-top: 1.1rem;
    max-width: 34ch;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(244, 242, 236, 0.55);
  }
  .footer-cta {
    margin-top: 1.75rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .footer-col__title {
    color: rgba(244, 242, 236, 0.55);
    margin-bottom: 0.4rem;
  }
  .footer-link {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: rgba(244, 242, 236, 0.78);
    transition: color 0.3s ease;
    width: fit-content;
  }
  .footer-link:hover {
    color: #f4f2ec;
  }
  .footer-link--static {
    cursor: default;
  }
  .footer-link--static:hover {
    color: rgba(244, 242, 236, 0.78);
  }

  .footer-rule {
    margin-block: 3rem 1.75rem;
  }
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    justify-content: space-between;
  }
  .footer-copy {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: rgba(244, 242, 236, 0.55);
  }
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
  }
  .footer-legal__link {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: rgba(244, 242, 236, 0.55);
    transition: color 0.3s ease;
  }
  .footer-legal__link:hover {
    color: #f4f2ec;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 2.5rem;
    }
    .footer-bottom {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
