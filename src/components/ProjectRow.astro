---
/**
 * Редакционная строка проекта (структура Lines).
 * Десктоп (≥1024): композиция «фото слева (4:5, ~40%) — текст справа,
 * по вертикали по центру; высота строки = высота фото».
 * Мобайл/планшет (<1024): стек — фото сверху, текст под ним.
 */
import Figure from './Figure.astro';
import { withBase } from '../lib/img.js';

interface Props {
  project: any;
  index: number;
  eager?: boolean;
}
const { project: p, index, eager = false } = Astro.props;
const line = p.tagline || p.essence;
const meta = [p.area, p.year, p.status].filter(Boolean).join(' · ');
const num = String(index + 1).padStart(2, '0');
// Клик-цель аналитики: явный goal проекта либо производный project_<slug>.
const goal = p.goal || `project_${p.slug.replace(/-/g, '_')}`;
---

<a class="prow" href={withBase(`/projects/${p.slug}/`)} data-goal={goal} data-reveal>
  <div class="prow__media">
    <Figure
      name={p.cover}
      alt={`${p.name} — ${p.type}`}
      ratio="4 / 5"
      eager={eager}
      imgClass="prow__img"
      sizes="(min-width: 1024px) 40vw, 100vw"
    />
  </div>

  <div class="prow__body">
    <span class="prow__num">{num}</span>
    <h2 class="prow__title">{p.name}</h2>
    {line && <p class="prow__idea">{line}</p>}
    <div class="prow__meta-wrap">
      <span class="prow__tag">{p.type}</span>
      {meta && <span class="prow__meta">{meta}</span>}
      {p.city && <span class="prow__loc">{p.city}</span>}
    </div>
    <span class="prow__cta">Смотреть<span class="arr" aria-hidden="true"> →</span></span>
  </div>
</a>

<style>
  .prow {
    display: block;
    padding-top: 2.25rem;
    border-top: 1px solid rgba(20, 20, 20, 0.14);
  }

  /* Медиа */
  .prow :global(.prow__img) {
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .prow:hover :global(.prow__img) {
    transform: scale(1.025);
  }

  /* Текстовая колонка */
  .prow__body {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .prow__num {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    color: #6a6a66;
  }
  .prow__title {
    margin-top: 0.6rem;
    font-size: clamp(1.85rem, 1.3rem + 2.4vw, 2.75rem);
    font-weight: 400;
    line-height: 1.04;
  }
  .prow__idea {
    margin-top: 0.75rem;
    max-width: 440px;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.55;
    color: #5f5f5b;
  }
  .prow__meta-wrap {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.9rem;
  }
  .prow__tag {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #141414;
    border: 1px solid rgba(20, 20, 20, 0.2);
    border-radius: 30px;
    padding: 0.35rem 0.8rem;
  }
  .prow__loc,
  .prow__meta {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6a6a66;
  }
  .prow__cta {
    margin-top: 1.35rem;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #141414;
  }
  .prow__cta .arr {
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .prow:hover .prow__cta .arr {
    transform: translateX(5px);
  }

  /* Десктоп: фото слева (~40%), текст справа по центру по вертикали */
  @media (min-width: 1024px) {
    .prow {
      display: flex;
      align-items: center;
      gap: clamp(2.5rem, 4vw, 5rem);
      padding-top: 2.75rem;
    }
    .prow__media {
      flex: 0 0 40%;
      max-width: 40%;
    }
    .prow__body {
      margin-top: 0;
      flex: 1 1 auto;
      max-width: 440px;
    }
  }
</style>
