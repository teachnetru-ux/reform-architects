---
import '../styles/fonts.css';
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import CookieBanner from './CookieBanner.astro';
import { site } from '../data/site.js';
import { resolveImage, withBase } from '../lib/img.js';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  headerTransparent?: boolean;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = 'og-default',
  headerTransparent = false,
  noindex = false,
} = Astro.props;

const fullTitle = title === site.name ? `${site.name} — ${site.tagline}` : `${title} — ${site.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImg = new URL(resolveImage(ogImage).src, Astro.site).href;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: Astro.site?.href,
  email: site.email,
  telephone: site.phone,
  foundingDate: String(site.established),
  description:
    'Архитектурное бюро полного цикла: дома, резиденции и интерьеры — от проекта до реализации в едином контуре ответственности.',
  logo: new URL(withBase('/full-logo.png'), Astro.site).href,
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Yandex.Metrika counter -->
    <script is:inline type="text/javascript">
        (function(m,e,t,r,i,k,a){
            m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
            m[i].l=1*new Date();
            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
        })(window, document,'script','https://mc.yandex.ru/metrika/tag.js', 'ym');

        ym(98224185, 'init', {webvisor:true, clickmap:true, referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/98224185" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#141414" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={withBase('/full-logo.png')} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />

    <!-- Fonts: Montserrat (Google Fonts, кириллица). Self-host своп — см. fonts.css -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />

    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">К содержимому</a>
    <Header transparent={headerTransparent} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieBanner />

    <script>
      // Reveal на скролле — с уважением к prefers-reduced-motion
      const els = document.querySelectorAll('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!('IntersectionObserver' in window) || reduce) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      }

      // Формы лидов: отправка через fetch на /lead.php без перезагрузки;
      // нативная валидация → сообщение успеха/ошибки → цель Метрики на успех.
      document.querySelectorAll('form[data-lead]').forEach((form) => {
        if (!(form instanceof HTMLFormElement)) return;
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (!form.checkValidity()) {
            form.reportValidity();
            return;
          }
          const body = form.querySelector('[data-form-body]');
          const ok = form.querySelector('[data-form-success]');
          const err = form.querySelector('[data-form-error]');
          const submitBtn = form.querySelector('button[type="submit"]');
          err?.setAttribute('hidden', '');
          submitBtn?.setAttribute('disabled', '');
          try {
            const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
            const json = await res.json();
            if (json && json.ok) {
              body?.setAttribute('hidden', '');
              ok?.removeAttribute('hidden');
              if (ok instanceof HTMLElement) ok.focus();
              const ym = (window as any).ym;
              if (typeof ym === 'function') ym(98224185, 'reachGoal', 'lead');
            } else {
              throw new Error('server');
            }
          } catch {
            if (err instanceof HTMLElement) {
              err.removeAttribute('hidden');
              err.focus();
            }
            submitBtn?.removeAttribute('disabled');
          }
        });
      });

      // Маска телефона: +7 (___) ___-__-__
      document.querySelectorAll<HTMLInputElement>('input[data-phone-mask]').forEach((el) => {
        const format = (raw: string) => {
          let d = raw.replace(/\D/g, '');
          if (d[0] === '8' || d[0] === '7') d = d.slice(1);
          d = d.slice(0, 10);
          let out = '+7';
          if (d.length > 0) out += ' (' + d.slice(0, 3);
          if (d.length >= 3) out += ')';
          if (d.length > 3) out += ' ' + d.slice(3, 6);
          if (d.length > 6) out += '-' + d.slice(6, 8);
          if (d.length > 8) out += '-' + d.slice(8, 10);
          return out;
        };
        el.addEventListener('input', () => {
          el.value = format(el.value);
        });
        el.addEventListener('focus', () => {
          if (!el.value) el.value = '+7 (';
        });
        el.addEventListener('blur', () => {
          if (el.value === '+7 (' || el.value === '+7') el.value = '';
        });
      });
    </script>

    <script is:inline src="/utm.js"></script>
  </body>
</html>
