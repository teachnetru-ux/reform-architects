---
import { site } from '../data/site.js';
import { withBase } from '../lib/img.js';

interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

// Цели Метрики для пунктов навигации (по href)
const navKey: Record<string, string> = {
  '/projects/': 'projects',
  '/developers/': 'developers',
  '#contact': 'contacts',
};
---

<header class:list={['site-header', transparent && 'site-header--transparent']} data-header>
  <div class="wrap site-header__inner">
    <a href={withBase('/')} class="wordmark" aria-label={`${site.name} — на главную`}>reform architects</a>

    <nav class="site-nav" aria-label="Основная навигация">
      {
        site.nav.map((item) => (
          <a
            href={withBase(item.href)}
            class="site-nav__link"
            data-goal={navKey[item.href] ? `nav_${navKey[item.href]}` : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="site-header__actions">
      <a href={withBase('#contact')} class="btn btn--ghost site-header__cta" data-goal="nav_cta">
        {site.cta.private}<span class="btn__arrow" aria-hidden="true">→</span>
      </a>
      <button
        type="button"
        class="burger"
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-burger
      >
        <span></span><span></span>
      </button>
    </div>
  </div>
</header>

{/*
  Полноэкранный оверлей вынесен ИЗ <header> намеренно: у шапки есть
  backdrop-filter, который делает её containing block для position:fixed
  потомков — из-за этого меню «уезжало»/обрезалось после скролла.
  Как сосед body оверлей всегда позиционируется от вьюпорта.
*/}
<div class="mobile-menu" id="mobile-menu" data-menu hidden>
  <div class="mobile-menu__bar">
    <a href={withBase('/')} class="mobile-menu__brand">reform architects</a>
    <button type="button" class="mobile-menu__close" aria-label="Закрыть меню" data-menu-close>
      <span></span><span></span>
    </button>
  </div>
  <nav class="mobile-menu__nav" aria-label="Мобильная навигация">
    {
      site.nav.map((item) => (
        <a
          href={withBase(item.href)}
          class="mobile-menu__link"
          data-goal={navKey[item.href] ? `nav_${navKey[item.href]}` : undefined}
        >
          {item.label}
        </a>
      ))
    }
    <a href={withBase('#contact')} class="btn btn--light mobile-menu__cta" data-goal="nav_cta">
      {site.cta.private}
    </a>
  </nav>
</div>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    height: var(--header-h);
    display: flex;
    align-items: center;
    color: #141414;
    background: rgba(242, 241, 236, 0.72);
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(20, 20, 20, 0.1);
    transition: background-color 0.4s ease, color 0.4s ease, border-color 0.4s ease;
  }
  .site-header--transparent {
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    border-bottom-color: transparent;
    color: #f4f2ec;
  }
  .site-header--transparent.is-scrolled {
    background: rgba(242, 241, 236, 0.72);
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
    border-bottom-color: rgba(20, 20, 20, 0.1);
    color: #141414;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    width: 100%;
  }

  .wordmark {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .site-nav {
    display: none;
    gap: 2rem;
  }
  .site-nav__link {
    position: relative;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding-block: 0.4rem;
  }
  .site-nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0.1rem;
    height: 1px;
    background: currentColor;
    opacity: 0.65;
    transition: right 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .site-nav__link:hover::after {
    right: 0;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .site-header__cta {
    display: none;
    padding: 0.7rem 1.2rem;
  }

  .burger {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    padding: 10px;
    background: none;
    border: 0;
    cursor: pointer;
    color: inherit;
  }
  .burger span {
    width: 24px;
    height: 1.5px;
    background: currentColor;
  }

  /* ── Полноэкранный мобильный оверлей ── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: flex;
    flex-direction: column;
    background: rgba(18, 18, 18, 0.98);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    color: #f4f2ec;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-menu__bar {
    flex: none;
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 20px;
    border-bottom: 1px solid rgba(244, 242, 236, 0.12);
  }
  .mobile-menu__brand {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: #f4f2ec;
  }
  .mobile-menu__close {
    position: relative;
    width: 44px;
    height: 44px;
    margin-right: -10px;
    background: none;
    border: 0;
    cursor: pointer;
    color: #f4f2ec;
  }
  .mobile-menu__close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 22px;
    height: 1.5px;
    background: currentColor;
  }
  .mobile-menu__close span:first-child {
    transform: translate(-50%, -50%) rotate(45deg);
  }
  .mobile-menu__close span:last-child {
    transform: translate(-50%, -50%) rotate(-45deg);
  }
  .mobile-menu__nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.25rem 20px 2.5rem;
  }
  .mobile-menu__link {
    font-family: var(--font-sans);
    font-size: clamp(1.1rem, 4.5vw, 1.45rem);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.2;
    padding-block: 1rem;
    border-bottom: 1px solid rgba(244, 242, 236, 0.12);
  }
  .mobile-menu__cta {
    margin-top: 1.75rem;
    align-self: flex-start;
  }

  @media (min-width: 1024px) {
    .site-nav {
      display: flex;
    }
    .site-header__cta {
      display: inline-flex;
    }
    .burger,
    .mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');
  const closeBtn = menu?.querySelector<HTMLButtonElement>('[data-menu-close]');

  // Шапка: прозрачная над hero → матовая после скролла
  if (header && header.classList.contains('site-header--transparent')) {
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  if (burger && menu) {
    const setOpen = (open: boolean) => {
      burger.setAttribute('aria-expanded', String(open));
      menu.hidden = !open;
      // Блокируем прокрутку фона, пока меню открыто (и возвращаем после)
      document.documentElement.style.overflow = open ? 'hidden' : '';
      if (open) closeBtn?.focus();
      else burger.focus();
    };

    burger.addEventListener('click', () => setOpen(true));
    closeBtn?.addEventListener('click', () => setOpen(false));
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hidden) setOpen(false);
    });
  }
</script>
